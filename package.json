{
  "name": "agent-diff-review-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "check": "pnpm -r --filter './packages/*' run check",
    "test": "vitest",
    "lint": "eslint . && markdownlint-cli2",
    "lint:fix": "eslint . --fix && markdownlint-cli2 --fix && prettier --write .",
    "release": "multi-semantic-release --sequential-init --first-parent",
    "postinstall": "node scripts/postinstall.js",
    "prepare": "pnpm build && husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/cli": "^4.1.14",
    "@types/node": "^24.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260313.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.1",
    "multi-semantic-release": "^3.0.2",
    "prettier": "^3.8.3",
    "semantic-release": "^24.2.9",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.1.11",
    "vitest": "^3.2.4"
  }
}
