{
  "name": "@cwygoda/agent-diff-review",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "agent-diff-review": "src/cli.ts"
  },
  "scripts": {
    "build:web": "npm run build:web:css && npm run build:web:js",
    "cli": "node --experimental-strip-types ./src/cli.ts",
    "claude:review": "node --experimental-strip-types ./src/claude-ui.ts",
    "build:web:css": "tailwindcss -i ./web/styles.css -o ./web/dist/styles.css --minify",
    "build:web:js": "vite build",
    "check": "tsgo --noEmit",
    "lint": "eslint . && markdownlint-cli2",
    "lint:fix": "eslint . --fix && markdownlint-cli2 --fix && prettier --write .",
    "test": "vitest",
    "release": "semantic-release",
    "prepare": "npm run build:web && husky"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "glimpseui": "^0.6.0",
    "monaco-editor": "^0.52.2"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/cli": "^4.1.14",
    "@types/node": "^24.5.2",
    "@typescript/native-preview": "^7.0.0-dev.20260313.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/npm": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "semantic-release": "^24.2.9",
    "tailwindcss": "^4.1.14",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.1.11",
    "vitest": "^3.2.4"
  }
}
